{
  "name": "guided-review",
  "private": true,
  "type": "module",
  "bin": {
    "guided-review": "bin/guided-review.ts"
  },
  "scripts": {
    "dev:web": "vite --config web/vite.config.ts",
    "dev:server": "bun --watch server/index.ts",
    "build": "vite build --config web/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "start": "bun bin/guided-review.ts"
  },
  "dependencies": {
    "@pierre/diffs": "^1.2.12",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  }
}
